# ========================
# Database
# ========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=park302
DB_USERNAME=
DB_PASSWORD=

# ========================
# JWT
# ========================
# 최소 32자 이상의 랜덤 문자열 권장 (예: openssl rand -base64 32)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ========================
# 관리자 계정
# ========================
ADMIN_USERNAME=admin
# BCrypt 해시값. 생성 방법: htpasswd -nbB -C 10 admin mypassword | cut -d: -f2
ADMIN_PASSWORD_HASH=

# ========================
# NCP Object Storage
# ========================
NCP_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_STORAGE_REGION_NAME=kr-standard
NCP_STORAGE_BUCKET_NAME=dashboard
# 버킷 내 루트 폴더 (dev: 로컬/개발, prod: 운영)
NCP_STORAGE_ROOT_DIR=dev
NCP_STORAGE_ACCESS_KEY=
NCP_STORAGE_SECRET_KEY=
